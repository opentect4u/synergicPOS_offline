<?xml version="1.0" encoding="utf-8"?>
<!--
  Result of a customer phone lookup on the billing screen: who was found, what
  they owe, and whether to put them on this sale.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="380dp"
    android:layout_height="wrap_content"
    app:cardCornerRadius="18dp"
    app:cardElevation="12dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Identity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="22dp"
            android:paddingTop="24dp"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/tvResultInitials"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="?"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_customer_avatar" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvResultStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CUSTOMER FOUND"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue" />

                <TextView
                    android:id="@+id/tvResultName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Customer"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_main" />

                <TextView
                    android:id="@+id/tvResultPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0000000000"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status chips -->
        <LinearLayout
            android:id="@+id/llResultChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="22dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvChipCredit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Credit"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_customer_chip"
                android:textColor="@color/text_main"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvChipBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="Due"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_customer_chip"
                android:textColor="@color/text_main"
                android:visibility="gone" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#EEEEEE" />

        <!-- Detail rows, hidden individually when empty -->
        <LinearLayout
            android:id="@+id/llResultDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="22dp"
            android:paddingVertical="8dp" />

        <TextView
            android:id="@+id/tvResultNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="22dp"
            android:paddingBottom="6dp"
            android:text=""
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingHorizontal="18dp"
            android:paddingTop="6dp"
            android:paddingBottom="18dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResultCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="Cancel"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResultUse"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:text="Add to sale"
                android:textColor="@color/white"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
