<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardReceipt"
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="22dp">

                <!-- Header logo (md_logos BILL_HEADER), hidden when none is set -->
                <ImageView
                    android:id="@+id/ivBillHeaderLogo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="76dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:layout_marginBottom="8dp"
                    android:contentDescription="Store logo"
                    android:visibility="gone" />

                <!-- Store name -->
                <TextView
                    android:id="@+id/tvStoreName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="JAI HANUMAN"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#111111" />

                <!-- Store address / phone / GSTIN, hidden individually when unset -->
                <TextView
                    android:id="@+id/tvStoreAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#444444"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvStorePhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="#444444"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvStoreGstin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="11sp"
                    android:textColor="#222222"
                    android:visibility="gone" />

                <!-- Configurable header lines (md_headers) -->
                <LinearLayout
                    android:id="@+id/llBillHeaderLines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Date | Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="17-07-2026"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:textColor="#333333" />

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="13:18"
                        android:fontFamily="monospace"
                        android:textSize="13sp"
                        android:textColor="#333333" />
                </LinearLayout>

                <TextView style="@style/BillDashLine" />

                <!-- Bill no / Name -->
                <TextView
                    android:id="@+id/tvBillNo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BILL NO: 3"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NAME  : SOMNATH"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="#222222" />

                <TextView
                    android:id="@+id/tvCustGstin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="13sp"
                    android:textColor="#222222"
                    android:visibility="gone" />

                <TextView style="@style/BillDashLine" />

                <!-- Items header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3.4"
                        android:text="SR.NO ITEM"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="QTY"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="PRICE"
                        android:gravity="end"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.2"
                        android:text="AMOUNT"
                        android:gravity="end"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />
                </LinearLayout>

                <TextView style="@style/BillDashLine" />

                <!-- Items -->
                <LinearLayout
                    android:id="@+id/llItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView style="@style/BillDashLine" />

                <!-- Tax header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="TAX%"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="B.AMT"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="SGST"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="CGST"
                        android:gravity="center"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2.2"
                        android:text="TOTAL"
                        android:gravity="end"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#222222" />
                </LinearLayout>

                <!-- Tax rows (built dynamically from the bill) -->
                <LinearLayout
                    android:id="@+id/llTaxRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp" />

                <!-- Round off, shown only when the bill carries one -->
                <LinearLayout
                    android:id="@+id/llRoundOff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ROUND OFF"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:textColor="#222222" />

                    <TextView
                        android:id="@+id/tvRoundOff"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:textColor="#222222" />
                </LinearLayout>

                <TextView style="@style/BillDashLine" />

                <!-- Grand total -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grand Total:"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111111" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹"
                        android:paddingStart="12dp"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#111111" />

                    <TextView
                        android:id="@+id/tvBillGrandTotal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="4dp"
                        android:text="962.50"
                        android:gravity="start"
                        android:maxLines="1"
                        android:fontFamily="monospace"
                        android:textStyle="bold"
                        android:textSize="22sp"
                        android:textColor="#111111" />
                </LinearLayout>

                <TextView style="@style/BillDashLine" />

                <!-- Amount in words -->
                <TextView
                    android:id="@+id/tvAmountWords"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:lineSpacingExtra="2dp"
                    android:textColor="#333333"
                    android:visibility="gone" />

                <!-- Payment mode, one row per payment recorded against the bill -->
                <LinearLayout
                    android:id="@+id/llBillPayment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Who rang the sale up -->
                <TextView
                    android:id="@+id/tvBillCreatedBy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Created by: ---"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textColor="#222222" />

                <TextView style="@style/BillDashLine" />

                <!-- Configurable footer lines (md_footers) -->
                <LinearLayout
                    android:id="@+id/llBillFooterLines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Footer logo (md_logos BILL_FOOTER), hidden when none is set -->
                <ImageView
                    android:id="@+id/ivBillFooterLogo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxHeight="56dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:layout_marginTop="8dp"
                    android:contentDescription="Footer logo"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:textColor="#555555" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>

    <!-- Floats over the receipt so it stays reachable while the bill scrolls -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPrintBill"
        android:layout_width="wrap_content"
        android:layout_height="46dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minHeight="0dp"
        android:text="Print"
        android:textColor="@color/white"
        app:icon="@drawable/ic_print"
        app:iconTint="@color/white"
        app:cornerRadius="12dp"
        app:elevation="4dp" />
</FrameLayout>
