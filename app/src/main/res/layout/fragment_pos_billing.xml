<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- ================= POS HEADER (modular cells) ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:gravity="center_vertical">

        <!-- Brand -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_vertical"
            android:paddingHorizontal="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYNERGIC POS"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvBrandSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="POS TERMINAL"
                android:textSize="9sp"
                android:letterSpacing="0.2"
                android:textColor="@color/primary_blue" />
        </LinearLayout>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <!-- Scrollable middle cells -->
        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <LinearLayout style="@style/PosHeaderCell">
                    <TextView style="@style/PosHeaderLabel" android:text="Cashier" />
                    <TextView
                        android:id="@+id/tvCashierName"
                        style="@style/PosHeaderValue"
                        android:text="Priya Nair" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

                <!-- <LinearLayout style="@style/PosHeaderCell">
                    <TextView style="@style/PosHeaderLabel" android:text="Register" />
                    <TextView style="@style/PosHeaderValue" android:text="Lane 03" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" /> -->

                <LinearLayout style="@style/PosHeaderCell">
                    <TextView style="@style/PosHeaderLabel" android:text="Order" />
                    <TextView android:id="@+id/tvHeaderOrder" style="@style/PosHeaderValue" android:text="INV-000001" />
                </LinearLayout>
            </LinearLayout>
        </HorizontalScrollView>

        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#EEEEEE" />

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="14dp"
            android:text="13:18"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalculator"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:text="Calculator"
            app:icon="@android:drawable/ic_dialog_dialer"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:id="@+id/btnHeld"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:text="Held (0)"
            app:cornerRadius="10dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#E0E0E0" />

    <!-- ================= BODY ================= -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- PRODUCT REGION -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Search + actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCustomer"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:layout_marginEnd="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minHeight="0dp"
                    android:text="Add Customer"
                    app:icon="@android:drawable/ic_menu_myplaces"
                    app:cornerRadius="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilSearch"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Scan barcode or search name / SK"
                    app:startIconDrawable="@android:drawable/ic_menu_search"
                    app:boxCornerRadiusTopStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusBottomEnd="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:imeOptions="actionSearch"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Category tab strip -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCategories"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@color/white"
                android:clipToPadding="false"
                tools:listitem="@layout/item_pos_category" />

            <View android:layout_width="match_parent" android:layout_height="2dp" android:background="#E0E0E0" />

            <!-- Product grid -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvProducts"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_pos_product" />

                <TextView
                    android:id="@+id/tvNoProducts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="No products found"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- Shortcut hints -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:scrollbars="none"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView style="@style/PosHint" android:text="F2 Hold" />
                    <TextView style="@style/PosHint" android:text="F4 Held Orders" />
                    <TextView style="@style/PosHint" android:text="F8 Customer" />
                    <TextView style="@style/PosHint" android:text="Enter Scan/Add" />
                    <TextView style="@style/PosHint" android:text="F9 Charge" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <View android:layout_width="2dp" android:layout_height="match_parent" android:background="#E0E0E0" />

        <!-- CART / ORDER TICKET -->
        <LinearLayout
            android:id="@+id/cartPanel"
            android:layout_width="340dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/white">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CURRENT SALE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:textColor="@color/primary_blue" />

                    <TextView
                        android:id="@+id/tvOrderNo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INV-000001"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main" />
                </LinearLayout>

                <!-- Total Item Count -->
                <TextView
                    android:id="@+id/tvItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 items"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />

                <!-- Customer -->
                <com.google.android.material.button.MaterialButton
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
                    android:id="@+id/btnAddCustomer"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="+ Add loyalty customer"
                    android:textSize="13sp"
                    app:rippleColor="@android:color/transparent" />

                <LinearLayout
                    android:id="@+id/llCustomerInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvCustName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Customer"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_main" />

                            <ImageButton
                                android:id="@+id/btnCustomerInfo"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="6dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:src="@android:drawable/ic_menu_info_details"
                                app:tint="@color/primary_blue"
                                android:contentDescription="Customer details"
                                android:visibility="gone" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCustSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="340 pts"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnRemoveCust"
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        app:tint="@color/text_secondary"
                        android:contentDescription="Remove customer" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

            <!-- Cart lines -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCart"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="8dp"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_pos_cart_line" />

                <!-- Floating Scroll Marker / Jump to Top -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnJumpTop"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="Show Newest"
                    android:textSize="10sp"
                    android:visibility="gone"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="16dp"
                    app:icon="@android:drawable/ic_menu_upload"
                    app:iconSize="12dp"
                    app:backgroundTint="@color/primary_blue"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tvCartEmpty"
                    android:layout_width="230dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="No items yet — scan or tap a product to begin."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </FrameLayout>

            <!-- Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F8F9FA"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <!-- Discount row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDiscount"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Discount"
                        app:suffixText="%"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDiscount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:gravity="end"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCouponMsg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="11sp"
                    android:textColor="@color/primary_dark"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Subtotal" android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvSubtotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹ 0.00" android:textSize="13sp" android:textColor="@color/text_main" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView android:id="@+id/tvDiscountLabel" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Discount (0%)" android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvDiscountAmt" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="- ₹ 0.00" android:textSize="13sp" android:textColor="@color/text_main" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="GST" android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvTax" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹ 0.00" android:textSize="13sp" android:textColor="@color/text_main" />
                </LinearLayout>

                <!-- Round off, shown only when the bill needs one -->
                <LinearLayout
                    android:id="@+id/rowBillingRoundOff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:visibility="gone">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Round off" android:textSize="13sp" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvBillingRoundOff" android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹ 0.00" android:textSize="13sp" android:textColor="@color/text_main" />
                </LinearLayout>
            </LinearLayout>

            <!-- Accent total bar -->
            <LinearLayout
                android:id="@+id/barTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/primary_blue"
                android:paddingHorizontal="16dp"
                android:paddingVertical="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TOTAL"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:textColor="@color/white" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0.00"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:background="@color/white">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHold"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Hold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCharge"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1.8"
                    android:layout_marginStart="8dp"
                    android:text="Checkout"
                    android:textColor="@color/white"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="@color/primary_blue"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
