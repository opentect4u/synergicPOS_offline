<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Scroll Marker (Accent for newest item) -->
        <View
            android:id="@+id/vNewMarker"
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:background="@color/primary_blue"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="10dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <!-- Name + unit price -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLineName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Item"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/text_main" />

                <TextView
                    android:id="@+id/tvLineEach"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹ 0 each"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- Qty stepper -->
            <ImageButton
                android:id="@+id/btnMinus"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_minus"
                app:tint="@color/text_secondary"
                android:contentDescription="Decrease" />

            <TextView
                android:id="@+id/tvQty"
                android:layout_width="28dp"
                android:layout_height="wrap_content"
                android:text="1"
                android:gravity="center"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_main" />

            <ImageButton
                android:id="@+id/btnPlus"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_add"
                app:tint="@color/text_secondary"
                android:contentDescription="Increase" />

            <!-- Line total -->
            <TextView
                android:id="@+id/tvLineTotal"
                android:layout_width="66dp"
                android:layout_height="wrap_content"
                android:text="₹ 0"
                android:gravity="end"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_main" />

            <ImageButton
                android:id="@+id/btnRemoveLine"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                app:tint="@color/menu_delete_icon"
                android:contentDescription="Remove" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE" />
</LinearLayout>
