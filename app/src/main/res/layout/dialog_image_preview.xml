<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
         android:layout_gravity="center_horizontal"
        android:gravity="center_horizontal">

        <!-- Caption header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvPreviewName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="19sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tvPreviewCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="DEPT001"
                android:textSize="14sp"
                android:gravity="center"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Full image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="340dp"
            android:background="#F1F3F4">

            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="Category image preview" />

            <TextView
                android:id="@+id/tvPreviewEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="No image uploaded"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Close action -->
        android:layout_width="520dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvPreviewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Image"
            android:textSize="19sp"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/text_main"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/ivPreview"
            android:layout_width="match_parent"
            android:layout_height="420dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            android:background="@color/bg_light"
            android:contentDescription="Full size preview" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPreviewClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_margin="20dp"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:text="Close"
            android:textColor="@color/white"
            app:cornerRadius="12dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
