<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header: title + remove -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvRateTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rate"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/text_main" />

            <ImageButton
                android:id="@+id/btnRemoveRate"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_minus"
                app:tint="@color/menu_delete_icon"
                android:contentDescription="Remove rate" />
        </LinearLayout>

        <!-- Row: Rate Name | Rate | Unit -->
        <LinearLayout style="@style/ProductFormRow" android:layout_marginTop="6dp">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginEnd="6dp" android:hint="Rate Name">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateName" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="text" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginHorizontal="6dp" android:hint="Rate">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRate" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormDropdown" android:layout_marginStart="6dp" android:hint="Unit">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/actRateUnit" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="none" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Row: CGST | SGST -->
        <LinearLayout style="@style/ProductFormRow">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginEnd="6dp" android:hint="CGST (%)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateCgst" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginStart="6dp" android:hint="SGST (%)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateSgst" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Row: IGST | VAT -->
        <LinearLayout style="@style/ProductFormRow">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginEnd="6dp" android:hint="IGST (%)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateIgst" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginStart="6dp" android:hint="VAT (%)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateVat" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Row: Discount | Discount Type -->
        <LinearLayout style="@style/ProductFormRow">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginEnd="6dp" android:hint="Discount">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateDiscount" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilRateDiscType"
                style="@style/ProductFormDropdown" android:layout_marginStart="6dp" android:hint="Discount Type">
                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/actRateDiscType" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="none" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Row: Sell Price | Purchase Price -->
        <LinearLayout style="@style/ProductFormRow">
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginEnd="6dp" android:hint="Sell Price">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRateSell" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/ProductFormField" android:layout_marginStart="6dp" android:hint="Purchase Price">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etRatePurchase" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:inputType="numberDecimal" android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
