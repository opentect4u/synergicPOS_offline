<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="820dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:id="@+id/tvProductFormTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Product"
            android:textSize="21sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/text_main"
            android:layout_marginBottom="20dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="300dp"
            android:layout_marginBottom="20dp"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Product image: preview + gallery/camera actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <ImageView
                        android:id="@+id/ivProductImage"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:background="@color/bg_light"
                        android:contentDescription="Product image"
                        android:src="@android:drawable/ic_menu_gallery" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="18dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Product Image"
                            android:textStyle="bold"
                            android:textColor="@color/text_main"
                            android:textSize="15sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="10dp">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickGallery"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gallery"
                                app:icon="@android:drawable/ic_menu_gallery"
                                app:cornerRadius="12dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTakePhoto"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Camera"
                                app:icon="@android:drawable/ic_menu_camera"
                                app:cornerRadius="12dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnClearImage"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="Clear" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row: Product Name | HSN Code -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilName"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="Product Name *">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilHsn"
                        style="@style/ProductFormField"
                        android:layout_marginStart="8dp"
                        android:hint="HSN Code">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHsn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: Barcode | Stock Alert Qty -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilBarcode"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="Barcode">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBarcode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilStockAlert"
                        style="@style/ProductFormField"
                        android:layout_marginStart="8dp"
                        android:hint="Stock Alert Qty">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStockAlert"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: Category | Batch No -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCategory"
                        style="@style/ProductFormDropdown"
                        android:layout_marginEnd="8dp"
                        android:hint="Category">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilBatchNo"
                        style="@style/ProductFormField"
                        android:layout_marginStart="8dp"
                        android:hint="Batch No">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBatchNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: Rate 1 | Unit 1 -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRate1"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="Rate 1">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRate1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUnit1"
                        style="@style/ProductFormDropdown"
                        android:layout_marginStart="8dp"
                        android:hint="Unit 1">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actUnit1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: Rate 2 | Unit 2 -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRate2"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="Rate 2">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRate2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUnit2"
                        style="@style/ProductFormDropdown"
                        android:layout_marginStart="8dp"
                        android:hint="Unit 2">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actUnit2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: Rate 3 | Unit 3 -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilRate3"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="Rate 3">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRate3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilUnit3"
                        style="@style/ProductFormDropdown"
                        android:layout_marginStart="8dp"
                        android:hint="Unit 3">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actUnit3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: CGST | SGST -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCgst"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="CGST Rate (%)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCgst"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSgst"
                        style="@style/ProductFormField"
                        android:layout_marginStart="8dp"
                        android:hint="SGST Rate (%)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSgst"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: IGST | VAT -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilIgst"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="IGST Rate (%)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etIgst"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilVat"
                        style="@style/ProductFormField"
                        android:layout_marginStart="8dp"
                        android:hint="VAT Rate (%)">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: Discount | Discount Type -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDiscount"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="Discount">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDiscount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDiscountType"
                        style="@style/ProductFormDropdown"
                        android:layout_marginStart="8dp"
                        android:hint="Discount Type">

                        <com.google.android.material.textfield.MaterialAutoCompleteTextView
                            android:id="@+id/actDiscountType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row: Sell Price | Purchase Price -->
                <LinearLayout style="@style/ProductFormRow">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSellPrice"
                        style="@style/ProductFormField"
                        android:layout_marginEnd="8dp"
                        android:hint="Sell Price">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSellPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPurchasePrice"
                        style="@style/ProductFormField"
                        android:layout_marginStart="8dp"
                        android:hint="Purchase Price">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPurchasePrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProductCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancel"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProductSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:text="Save"
                android:textColor="@color/white"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
